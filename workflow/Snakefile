rule surface_smooth:
    input:
        in_metric=bids(
            root="results/{dataset}/resampled2fsLR/32k_space_surfaces",
            datatype="func",
            desc="denoised",
            confounds="{confounds_idx}",
            hemi="{hemi}",
            space="fsLR_den-32k",
            suffix="bold.func.gii",
            subject="{subject}",
            task="{task}",
            run="{run}",
        ),
    output:
        bids(
            root="results/{dataset}/smoothed",
            datatype="func",
            desc="denoised",
            confounds="{confounds_idx}",
            fwhm="{fwhm}",
            hemi="{hemi}",
            space="fsLR_den-32k",
            suffix="bold.func.gii",
            subject="{subject}",
            task="{task}",
            run="{run}",
        ),
    params:
        # use canonical fsLR 32k midthickness surfaces shipped in resources
        midthick="resources/fsLR_32K_surfaces/fs_LR.32k.{hemi}.midthickness.surf.gii",
    container:
        config["singularity_connectome_workbench"]
    log:
        "logs/{dataset}/surface_smooth/sub-{subject}_{hemi}_fwhm-{fwhm}_confounds-{confounds_idx}_task-{task}_run-{run}.log",
    threads: 2
    shell:
        # if fwhm == 0 just copy the file; otherwise run wb_command metric-smoothing
        "if [ {wildcards.fwhm} -eq 0 ]; then \n"
        "  cp {input.in_metric} {output} 2> {log}; \n"
        "else \n"
        "  wb_command -metric-smoothing {params.midthick} {input.in_metric} -fwhm {wildcards.fwhm} {output} &> {log}; \n"
        "fi"

# Dummy rule
rule smooth_all:
