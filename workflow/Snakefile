## leave-one-out ISC
rule loo_ISC:
    input:
        func=ISC_gen_inputs,
    params:
        n_dummies=config['n_dummies'],
        n_volumes=config['n_volumes'],
    output:
        h5="results/{dataset}/looISC/{group}/looISC_task-{task}_hemi-{hemi}_fwhm-{fwhm}_confounds-{confounds_idx}_resampled-{resampled}_atlas-{atlas}.h5",
    script:
        "scripts/looISC.py"


# Dumy rule
# atlas = none would just use vertices as units
rule loo_ISC_movie:
    input:
        expand(
            expand(
                rules.loo_ISC.output.h5,
                dataset=config["dataset"],
                task=config["movie_name"],
                group="control",
                hemi=config["hemi"],
                fwhm="{fwhm}",
                confounds_idx=1,
                resampled=config["resampling"],
                atlas="{atlas}",
            ),
            zip,
            fwhm=[0] * len(config["parcellations"]) + config["fwhm"],
            atlas=config["parcellations"] + ["none"] * len(config["fwhm"]),
        ),


# default_target: True


rule ISC_all:
    input:
        loo = rules.loo_ISC_movie.input,
        pw = rules.pw_ISC_movie.input
    
    # default_target: True

## tSNR (first for the parcellated files only to be extended)
rule tSNR:
    input:
        ts=bids(root="results/{dataset}/{source}-parcellated/{atlas}",
                datatype="func",
                subject="{subject}",
                task="{task}",
                run="{run}",
                confounds="{confounds_idx}",
                hemi="{hemi}",
                suffix="bold.func.h5"
                )
    output:
        tSNR=bids(root="results/{dataset}/{source}-parcellated/{atlas}",
                datatype="func",
                subject="{subject}",
                task="{task}",
                run="{run}",
                confounds="{confounds_idx}",
                hemi="{hemi}",
                suffix="tSNR.h5"
                )
    script:
        "scripts/tSNR.py"

# Dummy rule
rule tSNR_parcellated:
    input:
        tSNR=expand(
                expand(rules.tSNR.output.tSNR,
                        zip,
                        **inputs["preproc_bold"].zip_lists,
                        allow_missing=True,
                    ),
                dataset=config["dataset"],
                source="resampled2fsLR/32k_space_surfaces",
                confounds_idx=range(1, len(config["confounds"]) + 1),
                hemi=config["hemi"],
                atlas=config["parcellations"],
                )
    default_target: True


## Archive results to project space as a SquashFS image
rule archive_results:
    input:
        rules.ISC_all.input.loo,
        rules.ISC_all.input.pw,
        rules.tSNR_parcellated.input.tSNR,
    params:
        src=f"results/{config['dataset']}",
        dest=config["archive_dir"].format(dataset=config["dataset"]),
    output:
        sqfs=config["archive_dir"].format(dataset=config["dataset"])
              + f"/{config['dataset']}_ISC-pipeline.sqfs",
    threads: 8
    resources:
        mem_mb=8000,
        runtime=120,
    shell:
        "mkdir -p {params.dest} && "
        "mksquashfs {params.src} {output.sqfs} -comp zstd -noappend -processors {threads}"
